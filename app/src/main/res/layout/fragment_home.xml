<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ============================================================ -->
            <!-- CARD 1: PERSONALIZED HERO HEADER                             -->
            <!-- ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_hero_gradient"
                    android:padding="20dp">

                    <!-- Wave icon + greeting -->
                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="GOOD MORNING, CAPTAIN!"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.02" />

                    <!-- Personalized subtitle -->
                    <TextView
                        android:id="@+id/tvCargoSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading your shipments..."
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp" />

                    <!-- 2x2 Stat Chip Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- IN TRANSIT chip -->
                        <LinearLayout
                            android:id="@+id/chipInTransit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_stat_chip"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_transit"
                                app:tint="@color/white"
                                android:alpha="0.9" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/tvInTransitCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="IN TRANSIT"
                                    android:textColor="#DDFFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- PROCESSING chip -->
                        <LinearLayout
                            android:id="@+id/chipProcessing"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_stat_chip"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_processing"
                                app:tint="@color/white"
                                android:alpha="0.9" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/tvProcessingCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PROCESSING"
                                    android:textColor="#DDFFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginTop="12dp">

                        <!-- DELIVERED chip -->
                        <LinearLayout
                            android:id="@+id/chipDelivered"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_stat_chip"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_delivered"
                                app:tint="@color/white"
                                android:alpha="0.9" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/tvDeliveredCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DELIVERED"
                                    android:textColor="#DDFFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- DELAYED chip -->
                        <LinearLayout
                            android:id="@+id/chipDelayed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_stat_chip"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_delayed"
                                app:tint="@color/white"
                                android:alpha="0.9" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/tvDelayedCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DELAYED"
                                    android:textColor="#DDFFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            <!-- ============================================================ -->
            <!-- CARD 2: FLEET STATUS PULSE                                   -->
            <!-- ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row: FLEET STATUS + active count badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_ferry_marker"
                            app:tint="@color/deep_ocean_blue"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="FLEET STATUS"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02" />

                        <!-- Active Vessel count badge -->
                        <TextView
                            android:id="@+id/tvActiveFerryCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ACTIVE"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/button_primary_small"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginBottom="12dp" />

                    <!-- Nearest ferry spotlight — visible when ferry data available -->
                    <LinearLayout
                        android:id="@+id/layoutNearestFerry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- Ferry name + status -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvNearestFerryName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="OceanJet 5"
                                android:textColor="@color/dark_text"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tvNearestFerryStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EN ROUTE"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:background="@drawable/bg_status_pill_open"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp" />
                        </LinearLayout>

                        <!-- Route -->
                        <TextView
                            android:id="@+id/tvNearestFerryRoute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manila → Cebu"
                            android:textColor="@color/medium_text"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"
                            android:layout_marginBottom="10dp" />

                        <!-- ETA + Progress bar row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvNearestFerryEta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- min"
                                android:textColor="@color/medium_text"
                                android:textSize="12sp" />

                            <ProgressBar
                                android:id="@+id/pbNearestFerry"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="10dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="@color/sky_cyan"
                                android:progressBackgroundTint="@color/light_gray" />

                            <TextView
                                android:id="@+id/tvNearestFerryProgress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/sky_cyan"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Empty / loading state for fleet -->
                    <TextView
                        android:id="@+id/tvFleetEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading fleet data..."
                        android:textColor="@color/medium_text"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:visibility="visible" />

                    <!-- View All Map button -->
                    <TextView
                        android:id="@+id/btnViewAllOnMap"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="VIEW ALL ON LIVE MAP →"
                        android:textColor="@color/sky_cyan"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:background="@drawable/button_outline_small"
                        android:paddingVertical="10dp"
                        android:layout_marginTop="16dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================ -->
            <!-- CARD 3: MY CARGO SNAPSHOT                                    -->
            <!-- ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row: title + count badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_my_cargo"
                            app:tint="@color/primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="FLEET CARGO PULSE"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02" />

                        <!-- Active count badge -->
                        <TextView
                            android:id="@+id/tvFleetCargoCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ACTIVE"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/button_primary_small"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginBottom="4dp" />

                    <!-- Dynamic cargo rows will be added here programmatically -->
                    <LinearLayout
                        android:id="@+id/llCargoRows"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- Empty state (no fleet cargo after load) -->
                    <LinearLayout
                        android:id="@+id/layoutCargoEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_my_cargo"
                            app:tint="@color/light_gray"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvCargoEmptyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No active shipments fleet-wide"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active shipments will appear here in real-time"
                            android:textColor="@color/light_text"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Loading state -->
                    <TextView
                        android:id="@+id/tvCargoLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Searching for fleet activity..."
                        android:textColor="@color/medium_text"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:visibility="visible" />

                    <!-- Explore All Shipments button -->
                    <TextView
                        android:id="@+id/btnTrackAllCargo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="EXPLORE ALL SHIPMENTS →"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:background="@drawable/button_outline_small"
                        android:paddingVertical="10dp"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================ -->
            <!-- CARD 4: PORT & WEATHER ADVISORY TICKER                       -->
            <!-- ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_ports"
                            app:tint="@color/deep_ocean_blue"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="PORTS &amp; ADVISORIES"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginBottom="10dp" />

                    <!-- Port status summary row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp"
                        android:weightSum="3">

                        <!-- Open Status -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/ic_status_dot_green"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvPortsOpen"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Open"
                                android:textColor="@color/safety_green"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="30dp"
                            android:background="@color/divider"
                            android:alpha="0.5" />

                        <!-- Limited Status -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/ic_status_dot_amber"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvPortsLimited"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Limited"
                                android:textColor="@color/warning_amber"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="30dp"
                            android:background="@color/divider"
                            android:alpha="0.5" />

                        <!-- Closed Status -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/ic_status_dot_red"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvPortsClosed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Closed"
                                android:textColor="@color/error_red"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Advisory banner (visible only when hasAdvisory == true) -->
                    <LinearLayout
                        android:id="@+id/layoutAdvisoryBanner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_advisory_banner"
                        android:padding="10dp"
                        android:layout_marginTop="4dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvAdvisoryText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No advisories"
                            android:textColor="#E65100"
                            android:textSize="13sp"
                            android:maxLines="3"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <!-- No ports/weather empty state -->
                    <TextView
                        android:id="@+id/tvPortsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No ports nearby"
                        android:textColor="@color/medium_text"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
