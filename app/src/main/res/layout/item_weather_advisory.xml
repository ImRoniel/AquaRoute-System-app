<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:id="@+id/weatherCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MANILA PORT"
                    android:textColor="@color/deep_ocean_blue"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPortType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/status_background"
                    android:backgroundTint="#F0F4F8"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="📍 PORT"
                    android:textColor="@color/medium_text"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvIconCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️ CLEAR SKY"
                android:textColor="@color/medium_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_gray"
            android:layout_marginVertical="12dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <TextView
                android:id="@+id/tvTemp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🌡️ Temperature: 28°C"
                android:textColor="@color/medium_text"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvWind"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="💨 Wind: 5m/s E"
                android:textColor="@color/medium_text"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvWaves"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🌊 Waves: 0.5m"
                android:textColor="@color/medium_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvHumidity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="💧 Humidity: 65%"
                android:textColor="@color/medium_text"
                android:textSize="13sp" />
        </GridLayout>

        <TextView
            android:id="@+id/tvAdvisoryMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/status_background"
            android:backgroundTint="#FFF1F1"
            android:padding="12dp"
            android:text="⚠️ Small vessels are advised not to sail due to high waves."
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
