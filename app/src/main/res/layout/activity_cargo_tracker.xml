<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splashscreen"
    android:orientation="vertical"
    tools:context=".View.CargoTrackerActivity">

    <!-- Top Bar -->
    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/deep_ocean_blue"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white"
                android:padding="12dp"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📦 CARGO TRACKER"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍 ENTER REFERENCE NUMBER"
                        android:textColor="@color/deep_ocean_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="e.g., CRG-56215413-6451"
                            android:background="@drawable/edittext_background"
                            android:paddingHorizontal="12dp"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textSize="14sp" />

                        <ImageButton
                            android:id="@+id/btnClearSearch"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_close"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/medium_text"
                            android:visibility="gone"
                            android:layout_marginHorizontal="4dp" />

                        <Button
                            android:id="@+id/btnTrack"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="TRACK"
                            android:background="@drawable/button_primary"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="16dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/searchInstruction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter the reference number provided by the shipping company"
                        android:textColor="@color/medium_text"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/loadingProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginVertical="20dp" />

            <!-- Empty State (Not Found) -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_cargo_placeholder"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargo Not Found"
                    android:textColor="@color/deep_ocean_blue"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No cargo found with this reference number"
                    android:textColor="@color/medium_text"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Result Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦 CARGO DETAILS"
                        android:textColor="@color/deep_ocean_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Tracking Number -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Reference:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTrackingNumberValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CRG-56215413-6451"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Cargo Type -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Cargo Type:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvCargoTypeValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Electronics"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Description -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Description:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDescriptionValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Electronics equipment"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Weight -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Weight:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvWeightValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="500 kg"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginVertical="12dp" />

                    <!-- Route -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚢 ROUTE INFORMATION"
                        android:textColor="@color/deep_ocean_blue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Origin -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Origin:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvOriginValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Manila"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Destination -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Destination:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDestinationValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cebu"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Assigned Ferry -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Ferry:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvFerryNameValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="MV OceanJet 8"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Status:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvFerryStatusValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="IN TRANSIT"
                            android:textColor="@color/success_green"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- ETA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="ETA:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvEtaValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mar 10, 2026 · 2:30 PM"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Progress (for in transit) -->
                    <LinearLayout
                        android:id="@+id/progressLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Progress:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />

                        <ProgressBar
                            android:id="@+id/progressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:progress="45"
                            android:progressTint="@color/deep_ocean_blue"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvProgressValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45%"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="12sp"
                            android:layout_gravity="end" />
                    </LinearLayout>

                    <!-- Delay Reason -->
                    <LinearLayout
                        android:id="@+id/delayReasonLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Delay Reason:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDelayReason"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Severe weather"
                            android:textColor="@color/error_red"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Recipient -->
                    <LinearLayout
                        android:id="@+id/recipientLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Recipient:"
                            android:textColor="@color/medium_text"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvRecipientValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Maria Santos"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginVertical="16dp" />

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/btnViewOnMap"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_outline"
                            android:text="🗺️ VIEW ON MAP"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/btnFullDetails"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_outline"
                            android:text="📋 FULL DETAILS"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginHorizontal="4dp" />

                        <TextView
                            android:id="@+id/btnNewSearch"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_primary"
                            android:text="🔄 NEW SEARCH"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>