<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/custom_backround1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Bar -->
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/deep_ocean_blue"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:padding="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📦 CARGO TRACKER"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Search Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/text_primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍 Enter Reference Number"
                        android:textColor="@color/deep_ocean_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etReferenceNumber"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:hint="AQR-2026-001"
                            android:background="@drawable/card_background"
                            android:paddingHorizontal="12dp"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1" />

                        <ImageButton
                            android:id="@+id/btnClear"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_close"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/medium_text"
                            android:visibility="gone"
                            android:layout_marginHorizontal="4dp" />

                        <Button
                            android:id="@+id/btnTrack"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="TRACK"
                            android:background="@drawable/button_primary_small"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="16dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recent Searches -->
            <TextView
                android:id="@+id/tvRecentSearches"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 RECENT SEARCHES"
                android:textColor="@color/deep_ocean_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentSearches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <!-- Progress Bar -->
            <ProgressBar

                android:id="@+id/cargoProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginVertical="20dp" />

            <!-- Cargo Details Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cargoDetailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CARGO DETAILS:"
                        android:textColor="@color/deep_ocean_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Cargo Information -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/light_gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📦 CARGO INFORMATION"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp" />

                            <GridLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:columnCount="2"
                                android:rowCount="2">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Type:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvCargoTypeValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Perishable Goods"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Weight:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvWeightValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="500 kg"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Volume:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvVolumeValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="2.5 m³"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Value:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvValueValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="₱150,000"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />
                            </GridLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Vessel Information -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/light_gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚢 VESSEL INFORMATION"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp" />

                            <GridLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:columnCount="2"
                                android:rowCount="3">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Ferry:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvFerryValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="MV OceanJet 8"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Route:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvRouteValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Manila → Cebu"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Departure:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvDepartureValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Feb 22, 2026 · 10:00 AM"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="ETA:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvEtaValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Feb 22, 2026 · 2:30 PM"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />
                            </GridLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Current Location -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="16dp"
                        app:cardBackgroundColor="@color/light_gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📍 CURRENT LOCATION"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp" />

                            <GridLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:columnCount="2"
                                android:rowCount="2">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Position:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvPositionValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="14.5°N, 120.9°E"
                                    android:textColor="@color/deep_ocean_blue"
                                    android:padding="4dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="Status:"
                                    android:textColor="@color/medium_text"
                                    android:padding="4dp" />

                                <TextView
                                    android:id="@+id/tvStatusValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:text="IN TRANSIT"
                                    android:textColor="@color/success_green"
                                    android:textStyle="bold"
                                    android:padding="4dp" />
                            </GridLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Progress:"
                                android:textColor="@color/medium_text"
                                android:layout_marginTop="8dp" />

                            <ProgressBar
                                android:id="@+id/loadingProgressBar"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:progress="45"
                                android:progressTint="@color/deep_ocean_blue"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/tvProgressValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="45%"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="12sp"
                                android:layout_gravity="end" />

                            <TextView
                                android:id="@+id/tvLastUpdateValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Last update: 2 minutes ago"
                                android:textColor="@color/medium_text"
                                android:textSize="12sp"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/btnViewOnMap"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_outline"
                            android:text="🗺️ VIEW ON MAP"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/btnFullDetails"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_outline"
                            android:text="📋 FULL DETAILS"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginHorizontal="4dp" />

                        <TextView
                            android:id="@+id/btnNotifyMe"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_primary"
                            android:text="🔔 NOTIFY ME"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>