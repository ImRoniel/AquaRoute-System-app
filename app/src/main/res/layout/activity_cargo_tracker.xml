<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    tools:context=".View.CargoTrackerActivity">

    <!-- Header / Back Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/deep_ocean_blue"
            android:padding="8dp"
            android:contentDescription="Back"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CARGO TRACKER"
            android:textColor="@color/deep_ocean_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Search Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/deep_ocean_blue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRACK SHIPMENT"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:hint="Enter Reference Number"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/deep_ocean_blue"
                            android:background="@drawable/edittext_background"
                            android:paddingHorizontal="16dp"
                            android:imeOptions="actionSearch"
                            android:inputType="textCapCharacters"
                            android:maxLines="1"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />

                        <ImageButton
                            android:id="@+id/btnClearSearch"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_close"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_medium"
                            android:visibility="gone"
                            android:layout_marginStart="4dp"
                            android:contentDescription="Clear search" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTrack"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="LOCATE SHIPMENT"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="12dp"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        app:elevation="2dp" />

                    <TextView
                        android:id="@+id/searchInstruction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verify your tracking ID via your receipt"
                        android:textColor="@color/text_medium"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:layout_gravity="center_horizontal"
                        android:alpha="0.8" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/loadingProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginVertical="20dp" />

            <!-- Result Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_my_cargo"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SHIPMENT DETAILS"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>

                    <!-- Details List -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <!-- Tracking Number -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="REFERENCE"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvTrackingNumberValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Status with Dot -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="STATUS"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05" />

                            <ImageView
                                android:id="@+id/ivCargoStatusDot"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/ic_status_dot_amber"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tvFerryStatusValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.02" />
                        </LinearLayout>

                        <!-- Cargo Type -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="CATEGORY"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvCargoTypeValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Weight -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="WEIGHT"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvWeightValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginVertical="16dp"
                        android:alpha="0.4" />

                    <!-- Route Section -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_ferry"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOGISTICS &amp; ROUTE"
                            android:textColor="@color/deep_ocean_blue"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <!-- Origin/Destination -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="ORIGIN"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvOriginValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="DESTINATION"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDestinationValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Vessel -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="VESSEL"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvFerryNameValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- ETA -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="EST. ARRIVAL"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvEtaValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/deep_ocean_blue"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Progress (conditional) -->
                        <LinearLayout
                            android:id="@+id/progressLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp"
                            android:visibility="gone">

                            <ProgressBar
                                android:id="@+id/progressBar"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:progressTint="@color/primary"
                                android:backgroundTint="@color/light_gray" />

                            <TextView
                                android:id="@+id/tvProgressValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/primary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_gravity="end"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Spacing -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="24dp" />

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewOnMap"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="VIEW"
                            android:textColor="@color/primary"
                            app:strokeColor="@color/primary"
                            app:cornerRadius="8dp"
                            android:layout_marginEnd="6dp"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNewSearch"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="NEW"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="8dp"
                            android:layout_marginStart="6dp"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Empty State (Not Found) -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_cargo_placeholder"
                    android:layout_marginBottom="24dp"
                    android:alpha="0.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shipment Not Found"
                    android:textColor="@color/deep_ocean_blue"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="We couldn't locate any records for this reference number. Please verify and try again."
                    android:textColor="@color/text_medium"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:alpha="0.8" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Map Preview Panel (slides up from bottom) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cargoMapPreviewPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@color/primary">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_ferry"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/tvPreviewFerryName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Vessel Tracking"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageButton
                    android:id="@+id/btnCloseCargoMap"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:contentDescription="Close map preview" />
            </LinearLayout>

            <!-- Map Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">
                
                <org.osmdroid.views.MapView
                    android:id="@+id/cargoMiniMapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
                
                <!-- Overlay shadow for depth -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_status_pill_open"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>