<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_loginsignup.xml — Maritime Theme Overhaul
    Auth selection screen: user chooses Login or Create Account.
    Binding IDs preserved: btnLogin, btnSignup
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/auth_background">

    <!-- ── Centered Brand + Action Group ────────────────── -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo icon -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_aquaroute_logo"
            android:contentDescription="AquaRoute Logo"
            android:layout_marginBottom="20dp" />

        <!-- App name -->
        <TextView
            android:id="@+id/tvAppLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="8dp" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maritime Operations Platform"
            android:textColor="#B2C8E0"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="52dp" />

        <!-- Login button (filled navy-contrast white) -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#FFFFFF"
            android:text="Login"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp"
            app:cornerRadius="28dp" />

        <!-- Create Account button (ghost / outline) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>