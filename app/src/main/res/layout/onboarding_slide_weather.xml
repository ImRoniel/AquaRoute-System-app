<?xml version="1.0" encoding="utf-8"?>
<!--
    onboarding_slide_weather.xml — Maritime Theme
    Binding IDs preserved: imgIllustration, tvOnboardingTitle, tvOnboardingDescription
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingStart="36dp"
    android:paddingEnd="36dp"
    android:paddingBottom="16dp">

    <!-- Illustration -->
    <ImageView
        android:id="@+id/imgIllustration"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/weather_3d"
        android:scaleType="fitCenter"
        android:layout_marginBottom="36dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvOnboardingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_title_3"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:letterSpacing="-0.02"
        android:layout_marginBottom="14dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvOnboardingDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_desc_3"
        android:textColor="#B2C8E0"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:alpha="0.9" />

</LinearLayout>