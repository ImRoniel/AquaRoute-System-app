<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splashscreen"
    tools:context=".View.MainDashboard">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            layout="@layout/toolbar_main"
            android:id="@+id/toolbarLayout" />

        <!-- Navigation Host Fragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_main" />

        <!-- GitHub-style Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/bottom_nav_colors"
            app:itemTextColor="@color/bottom_nav_colors"
            app:elevation="8dp" />
    </LinearLayout>

    <!-- Navigation Drawer -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:orientation="vertical">

        <!-- Drawer Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/deep_ocean_blue"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/icon_background"
                android:gravity="center"
                android:text="👤"
                android:textSize="40sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/drawerUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/drawerUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.8" />

            <TextView
                android:id="@+id/drawerViewProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[VIEW PROFILE]"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Drawer Menu Items -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/drawerDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableLeft="@drawable/ic_dashboard"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/deep_ocean_blue"
                    android:text="DASHBOARD"
                    android:textColor="@color/deep_ocean_blue"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/drawerLiveMap"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableLeft="@drawable/ic_live_map"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="LIVE MAP"
                    android:textColor="@color/medium_text"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/drawerMyCargo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableLeft="@drawable/ic_my_cargo"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="MY CARGO"
                    android:textColor="@color/medium_text"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

<!--                <TextView-->
<!--                    android:id="@+id/drawerPorts"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="48dp"-->
<!--                    android:text="⚓  [PORTS &amp; STATUS]"-->
<!--                    android:textColor="@color/medium_text"-->
<!--                    android:textSize="16sp"-->
<!--                    android:gravity="center_vertical"-->
<!--                    android:paddingStart="16dp"-->
<!--                    android:background="?attr/selectableItemBackground" />-->

<!--                <TextView-->
<!--                    android:id="@+id/drawerVoyageHistory"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="48dp"-->
<!--                    android:text="📊  [VOYAGE HISTORY]"-->
<!--                    android:textColor="@color/medium_text"-->
<!--                    android:textSize="16sp"-->
<!--                    android:gravity="center_vertical"-->
<!--                    android:paddingStart="16dp"-->
<!--                    android:background="?attr/selectableItemBackground" />-->

<!--                <TextView-->
<!--                    android:id="@+id/drawerSavedRoutes"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="48dp"-->
<!--                    android:text="⭐  [SAVED ROUTES]"-->
<!--                    android:textColor="@color/medium_text"-->
<!--                    android:textSize="16sp"-->
<!--                    android:gravity="center_vertical"-->
<!--                    android:paddingStart="16dp"-->
<!--                    android:background="?attr/selectableItemBackground" />-->

                <TextView
                    android:id="@+id/drawerWeather"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableLeft="@drawable/ic_weather"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="WEATHER ADVISORIES"
                    android:textColor="@color/medium_text"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/drawerSupport"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableLeft="@drawable/ic_support"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="SUPPORT &amp; HELP"
                    android:textColor="@color/medium_text"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/drawerSettings"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableLeft="@drawable/ic_settings"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="SETTINGS"
                    android:textColor="@color/medium_text"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/light_gray"
                    android:layout_marginVertical="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📢 ANNOUNCEMENTS"
                    android:textColor="@color/deep_ocean_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• New ferry route: Manila - Palawan"
                    android:textColor="@color/medium_text"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• App version 2.0 released"
                    android:textColor="@color/medium_text"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp" />
            </LinearLayout>
        </ScrollView>

        <!-- Logout Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="4dp"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/light_gray">

            <TextView
                android:id="@+id/drawerLogout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:drawableLeft="@drawable/ic_logout"
                android:drawablePadding="16dp"
                android:drawableTint="@color/error_red"
                android:paddingStart="16dp"
                android:text="LOGOUT"
                android:textColor="@color/error_red"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>