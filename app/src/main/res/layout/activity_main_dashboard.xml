<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splashscreen"
    tools:context=".View.MainDashboard">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            layout="@layout/toolbar_main"
            android:id="@+id/toolbarLayout" />

        <!-- Navigation Host Fragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_main" />

        <!-- GitHub-style Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/bottom_nav_colors"
            app:itemTextColor="@color/bottom_nav_colors"
            app:elevation="8dp" />
    </LinearLayout>

    <!-- Navigation Drawer -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:orientation="vertical">

        <!-- Drawer Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/deep_ocean_blue"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/icon_background"
                android:gravity="center"
                android:text="👤"
                android:textSize="40sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/drawerUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/drawerUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.8" />

            <TextView
                android:id="@+id/drawerViewProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[VIEW PROFILE]"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Drawer Menu Items -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="QUICK ACCESS"
                    android:textColor="@color/deep_ocean_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp" />

                <!-- Weather Advisories -->
                <TextView
                    android:id="@+id/drawerWeather"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:drawableLeft="@drawable/ic_weather"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="Weather Advisories"
                    android:textColor="@color/medium_text"
                    android:textSize="15sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <!-- Ports Directory -->
                <TextView
                    android:id="@+id/drawerPorts"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:drawableLeft="@drawable/ic_ports"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="Ports Directory"
                    android:textColor="@color/medium_text"
                    android:textSize="15sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <!-- Voyage History -->
                <TextView
                    android:id="@+id/drawerVoyageHistory"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:drawableLeft="@drawable/ic_transit"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="Voyage History"
                    android:textColor="@color/medium_text"
                    android:textSize="15sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/light_gray"
                    android:layout_marginVertical="4dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT"
                    android:textColor="@color/deep_ocean_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <!-- My Profile -->
                <TextView
                    android:id="@+id/drawerProfile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:drawableLeft="@drawable/ic_person"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="My Profile"
                    android:textColor="@color/medium_text"
                    android:textSize="15sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

                <!-- Settings -->
                <TextView
                    android:id="@+id/drawerSettings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:drawableLeft="@drawable/ic_settings"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/medium_text"
                    android:text="Settings"
                    android:textColor="@color/medium_text"
                    android:textSize="15sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:background="?attr/selectableItemBackground" />

            </LinearLayout>
        </ScrollView>

        <!-- Logout Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="4dp"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/light_gray">

            <TextView
                android:id="@+id/drawerLogout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:drawableLeft="@drawable/ic_logout"
                android:drawablePadding="16dp"
                android:drawableTint="@color/error_red"
                android:paddingStart="16dp"
                android:text="LOGOUT"
                android:textColor="@color/error_red"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>