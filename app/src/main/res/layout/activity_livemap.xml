<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/custom_backround1">

    <!-- LAYER 1: FULL SCREEN MAP -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- LAYER 2: TOP BAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/deep_ocean_blue"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white"
                android:padding="12dp"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🗺️ LIVE MAP"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white"
                android:padding="12dp"
                android:contentDescription="Settings" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- STATUS OVERLAY (Top Right) -->
    <LinearLayout
        android:id="@+id/statusOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/topBar"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#99000000"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvLiveStatus"
            android:text="● LIVE"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvLastUpdate"
            android:text="Last update: --:--"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvConnection"
            android:text="ONLINE"
            android:textColor="#00E5FF"
            android:textSize="11sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- LAYER 3: MAP CONTROLS (BOTTOM RIGHT) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="120dp"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#E6000000"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/btnZoomIn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_zoom_in"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:scaleType="center"
                    android:contentDescription="Zoom In" />

                <ImageButton
                    android:id="@+id/btnZoomOut"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_zoom_out"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:scaleType="center"
                    android:layout_marginTop="4dp"
                    android:contentDescription="Zoom Out" />

                <ImageButton
                    android:id="@+id/btnTogglePorts"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_port_marker"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:scaleType="center"
                    android:layout_marginTop="4dp"
                    android:contentDescription="Toggle Ports" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#E6000000"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/btnMyLocation"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_my_location"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:scaleType="center"
                    android:contentDescription="My Location" />

                <ImageButton
                    android:id="@+id/btnSatellite"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_layers"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:scaleType="center"
                    android:layout_marginTop="4dp"
                    android:contentDescription="Toggle Satellite" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- LAYER 4: BOTTOM SHEET (VESSEL DETAILS) -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bottom_sheet_background"
        android:orientation="vertical"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="#666666"
            android:layout_marginBottom="8dp" />

        <!-- Vessel Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvVesselName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🚢 OceanJet 8"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVesselEta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱️ 25 mins"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnCloseSheet"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Route and Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvVesselRoute"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Route: Manila → Batangas"
                android:textColor="@color/medium_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvVesselLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Off Nasugbu"
                android:textColor="@color/medium_text"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Status and Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvVesselStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🟢 ON TIME"
                android:textColor="@color/success_green"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVesselSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ 25 knots"
                android:textColor="@color/medium_text"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/btnPassengerView"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:text="🚶‍➡️ PASSENGER"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/btnCargoView"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:text="📦 CARGO"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginHorizontal="4dp" />

            <TextView
                android:id="@+id/btnAlerts"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:text="🔔 ALERTS"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>