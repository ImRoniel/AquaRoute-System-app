<?xml version="1.0" encoding="utf-8"?>
<!--
    item_ferry.xml — Maritime Theme Ferry Card
    Binding IDs: tvFerryName, tvFerryRoute, tvFerryStatus, tvFerrySpeed,
                 tvFerryEta, tvFerryDistance, btnTrackFerry,
                 viewStatusStrip (NEW — left accent bar)
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- ── Colored status accent strip on the left ──────────────── -->
        <View
            android:id="@+id/viewStatusStrip"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="#4CAF50" />

        <!-- ── Card content ──────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Row 1: Icon + Name/Route + Status Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Ferry icon in a tinted circle -->
                <ImageView
                    android:id="@+id/ivFerryIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_ferries"
                    app:tint="@color/deep_ocean_blue"
                    android:background="@drawable/icon_background"
                    android:padding="8dp" />

                <!-- Name + route -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvFerryName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ferry Name"
                        android:textColor="@color/deep_ocean_blue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvFerryRoute"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Origin → Destination"
                        android:textColor="@color/medium_text"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Status pill badge -->
                <TextView
                    android:id="@+id/tvFerryStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ON TIME"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_status_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_gray"
                android:layout_marginVertical="10dp" />

            <!-- Row 2: Stats — Speed | ETA | Distance | Track button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- SPEED -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPEED"
                        android:textColor="@color/light_text"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tvFerrySpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— kn"
                        android:textColor="@color/dark_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- ETA -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ETA"
                        android:textColor="@color/light_text"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tvFerryEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TBD"
                        android:textColor="@color/dark_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- DISTANCE -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISTANCE"
                        android:textColor="@color/light_text"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tvFerryDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— km"
                        android:textColor="@color/dark_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Track button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTrackFerry"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Track"
                    android:textSize="12sp"
                    android:paddingHorizontal="14dp"
                    android:backgroundTint="@color/deep_ocean_blue"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_live_map"
                    app:iconSize="14dp" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
