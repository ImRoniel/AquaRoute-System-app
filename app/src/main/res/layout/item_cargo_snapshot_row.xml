<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="4dp">

    <!-- Status Dot -->
    <ImageView
        android:id="@+id/ivCargoStatusDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:src="@drawable/ic_status_dot_amber"
        android:layout_marginHorizontal="6dp" />

    <!-- Reference + Route -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_my_cargo"
                app:tint="@color/text_medium"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvCargoReference"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/dark_text"
                android:text="AQ-2024-001"
                android:letterSpacing="0.02" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCargoRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/medium_text"
            android:text="Manila → Cebu"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="20dp" />
    </LinearLayout>

    <!-- Status Label -->
    <TextView
        android:id="@+id/tvCargoStatusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/safety_green"
        android:text="IN TRANSIT"
        android:background="@drawable/bg_status_pill_open"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:letterSpacing="0.03" />

</LinearLayout>
