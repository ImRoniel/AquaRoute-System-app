<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="4dp">

    <!-- Status Dot -->
    <TextView
        android:id="@+id/tvCargoStatusDot"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:gravity="center"
        android:textSize="14sp"
        android:text="🟡" />

    <!-- Reference + Route -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvCargoReference"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:text="AQ-2024-001" />

        <TextView
            android:id="@+id/tvCargoRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/medium_text"
            android:text="Manila → Cebu"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Status Label -->
    <TextView
        android:id="@+id/tvCargoStatusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/safety_green"
        android:text="IN TRANSIT"
        android:background="@drawable/bg_status_pill_open"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp" />

</LinearLayout>
