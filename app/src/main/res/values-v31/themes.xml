<?xml version="1.0" encoding="utf-8"?>
<!--
    values-v31/themes.xml
    Overrides Base.Theme.AquaRouteSystem on Android 12+ (API 31+) to add
    native SplashScreen API attributes. These cannot live in the base
    values/themes.xml because minSdk=24 and they'd fail lint.
-->
<resources>
    <style name="Base.Theme.AquaRouteSystem" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/deep_ocean_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/deep_ocean_blue</item>

        <!-- Native Android 12+ Splash Screen attributes -->
        <!--
            ic_splash_icon: 600×600 viewport, logo at 50% scale + centered.
            This ensures Android's circular mask NEVER crops the logo edges.
        -->
        <item name="android:windowSplashScreenBackground">#0A4D8C</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>

        <!--
            windowSplashScreenBrandingImage: Place your branding PNG at
            res/drawable-xxhdpi/branding_text.png (see dimension guide below)
        -->
        <item name="android:windowSplashScreenBrandingImage">@drawable/branding_text</item>
    </style>
</resources>
