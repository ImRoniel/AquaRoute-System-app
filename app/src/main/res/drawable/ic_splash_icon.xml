<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_splash_icon.xml — Dedicated Android 12+ Splash Screen Icon

    PROBLEM:  windowSplashScreenAnimatedIcon fills its viewport edge-to-edge.
              Android's circular mask crops the edges — logo appears zoomed.

    SOLUTION: 600×600 square viewport. Logo path is scaled to 50% and centered,
              giving it large transparent padding so the circular mask never crops.

    MATH (scale = 0.50):
      Original path bounding box: 242 × 278 viewport units
      Scaled size: 242×0.50 = 121  ×  278×0.50 = 139
      Center in 600×600:
        translateX = (600 - 121) / 2 = 239.5 → 240
        translateY = (600 - 139) / 2 = 230.5 → 231
      (scaleX/Y pivot is 0,0 → translate shifts the scaled path to center)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="600"
    android:viewportHeight="600">

    <group
        android:scaleX="0.75"
        android:scaleY="0.75"
        android:translateX="209"
        android:translateY="196">

        <path
            android:fillColor="#FFFFFF"
            android:pathData="
                M211.1,263.1
                H34.6
                L10.1,186.1
                H101.6
